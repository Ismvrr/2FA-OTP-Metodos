{
  "info": {
    "name": "2FA OTP Service",
    "description": "Endpoints para envio y verificacion de codigos OTP por Email (Brevo) y WhatsApp (Chat2Desk HSM verifycode)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "2fa-otp-service"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://tudominio.com"
    },
    {
      "key": "api_key",
      "value": "cambia-esta-clave"
    }
  ],
  "item": [
    {
      "name": "Envio de OTP",
      "item": [
        {
          "name": "Enviar OTP por Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "API-Key", "value": "{{api_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"email\",\n  \"email\": \"destino@ejemplo.com\"\n}"
            },
            "url": { "raw": "{{base_url}}/otp/send", "host": ["{{base_url}}"], "path": ["otp", "send"] }
          },
          "response": [
            {
              "name": "Exitoso",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 0,\n  \"status\": \"SUCCESS\",\n  \"errorMessage\": \"OK\"\n}"
            },
            {
              "name": "Error",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 500,\n  \"status\": \"ERROR\",\n  \"errorMessage\": \"Error al enviar email\"\n}"
            }
          ]
        },
        {
          "name": "Enviar OTP por WhatsApp",
          "request": {
            "method": "POST",
            "header": [
              { "key": "API-Key", "value": "{{api_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"whatsapp\",\n  \"telefono\": \"521550000000\"\n}"
            },
            "url": { "raw": "{{base_url}}/otp/send", "host": ["{{base_url}}"], "path": ["otp", "send"] }
          },
          "response": [
            {
              "name": "Exitoso",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 0,\n  \"status\": \"SUCCESS\",\n  \"errorMessage\": \"OK\"\n}"
            },
            {
              "name": "Error",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 500,\n  \"status\": \"ERROR\",\n  \"errorMessage\": \"Error al enviar WhatsApp\"\n}"
            }
          ]
        },
        {
          "name": "Enviar OTP por Email y WhatsApp",
          "request": {
            "method": "POST",
            "header": [
              { "key": "API-Key", "value": "{{api_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"both\",\n  \"email\": \"destino@ejemplo.com\",\n  \"telefono\": \"521550000000\"\n}"
            },
            "url": { "raw": "{{base_url}}/otp/send", "host": ["{{base_url}}"], "path": ["otp", "send"] }
          },
          "response": [
            {
              "name": "Exitoso",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 0,\n  \"status\": \"SUCCESS\",\n  \"errorMessage\": \"OK\"\n}"
            },
            {
              "name": "Error parcial",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 500,\n  \"status\": \"ERROR\",\n  \"errorMessage\": \"Error al enviar: email, whatsapp\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Verificacion de OTP",
      "item": [
        {
          "name": "Verificar codigo OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "API-Key", "value": "{{api_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp_code\": \"AB12CD\"\n}"
            },
            "url": { "raw": "{{base_url}}/otp/verify", "host": ["{{base_url}}"], "path": ["otp", "verify"] }
          },
          "response": [
            {
              "name": "Codigo valido",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 0,\n  \"status\": \"SUCCESS\",\n  \"errorMessage\": \"OK\"\n}"
            },
            {
              "name": "Codigo invalido",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 401,\n  \"status\": \"ERROR\",\n  \"errorMessage\": \"OTP no encontrado\"\n}"
            },
            {
              "name": "Codigo expirado",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 401,\n  \"status\": \"ERROR\",\n  \"errorMessage\": \"OTP expirado\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Configuracion",
      "item": [
        {
          "name": "Ver configuracion actual",
          "request": {
            "method": "GET",
            "header": [
              { "key": "API-Key", "value": "{{api_key}}", "type": "text" }
            ],
            "url": { "raw": "{{base_url}}/otp/config", "host": ["{{base_url}}"], "path": ["otp", "config"] }
          },
          "response": [
            {
              "name": "Configuracion",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 0,\n  \"status\": \"SUCCESS\",\n  \"errorMessage\": \"OK\",\n  \"data\": {\n    \"MAIL_FROM\": \"info@tudominio.com\",\n    \"MAIL_USER\": \"usuario@smtp-brevo.com\",\n    \"MAIL_PASSWORD\": \"********\",\n    \"MAIL_SERVER\": \"smtp-relay.brevo.com\",\n    \"MAIL_PORT\": \"587\",\n    \"CHAT2DESK_TOKEN\": \"********\",\n    \"CHAT2DESK_CHANNEL_ID\": \"12345\",\n    \"OTP_LENGTH\": 6,\n    \"OTP_TYPE\": \"alphanumeric\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Actualizar parametros OTP",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "API-Key", "value": "{{api_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"length\": 8,\n  \"type\": \"numeric\"\n}"
            },
            "url": { "raw": "{{base_url}}/otp/params", "host": ["{{base_url}}"], "path": ["otp", "params"] }
          },
          "response": [
            {
              "name": "Actualizado",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"errorCode\": 0,\n  \"status\": \"SUCCESS\",\n  \"errorMessage\": \"OK\",\n  \"data\": {\n    \"MAIL_FROM\": \"info@tudominio.com\",\n    \"MAIL_USER\": \"usuario@smtp-brevo.com\",\n    \"MAIL_PASSWORD\": \"********\",\n    \"MAIL_SERVER\": \"smtp-relay.brevo.com\",\n    \"MAIL_PORT\": \"587\",\n    \"CHAT2DESK_TOKEN\": \"********\",\n    \"CHAT2DESK_CHANNEL_ID\": \"12345\",\n    \"OTP_LENGTH\": 8,\n    \"OTP_TYPE\": \"numeric\"\n  }\n}"
            }
          ]
        }
      ]
    }
  ]
}
